rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── APPOINTMENTS ──────────────────────────────────────────
    // Any authenticated user can create; only owner can read/update
    match /appointments/{apptId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['name','phone','service','date','userId'])
        && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── USER PROFILES ─────────────────────────────────────────
    // Users can only access their own profile
    match /user_profiles/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── JOE AI SESSIONS ───────────────────────────────────────
    match /joe_sessions/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── PQR (Petitions / Complaints / Claims) ─────────────────
    match /pqrs/{pqrId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── ADMIN NOTIFICATIONS (write-only by clients) ───────────
    // Admin reads via Firebase Admin SDK on server — not via client
    match /admin_notifications/{notifId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

  }
}
